/* ==UserStyle==
@name         Flat
@version      20260404.13.44
@namespace    github.com/ancandi/Flat-CSS
@description  Userstyle/CSS snippet to remove border-radius and flatten all UI.
@author       ancandi
@license      MIT
==/UserStyle== */

*,
*::before,
*::after {
    border-radius: 0 !important;
}
::-webkit-scrollbar-thumb {
    border-radius: 0 !important;
}
