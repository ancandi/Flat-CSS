/* ==UserStyle==
@name           Flat Global
@version        20260404.14.00
@namespace      github.com/ancandi/Flat-CSS
@description    Userstyle/CSS snippet to remove border-radius and flatten all UI.
@author         ancandi
@license        MIT
==/UserStyle== */

@-moz-document regexp(".*") {
    *,
    *::before,
    *::after {
        border-radius: 0 !important;
    }
    ::-webkit-scrollbar,
    ::-webkit-scrollbar-thumb,
    ::-webkit-scrollbar-track,
    ::-webkit-scrollbar-corner {
        border-radius: 0 !important;
    }
    [style*="clip-path: circle"],
    [style*="border-radius"] {
        clip-path: none !important;
        border-radius: 0 !important;
    }
    rect {
        rx: 0 !important;
        ry: 0 !important;
    }
}
